# Unified Nginx Configuration for Irishof.cloud (Managed by Gemini)

# 1. Latex (latex.irishof.cloud)
server {
    listen 443 ssl http2;
    server_name latex.irishof.cloud;
    ssl_certificate /etc/letsencrypt/live/latex.irishof.cloud/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/latex.irishof.cloud/privkey.pem;
    include /etc/letsencrypt/options-ssl-nginx.conf;
    ssl_dhparam /etc/letsencrypt/ssl-dhparams.pem;
    location / {
        proxy_pass http://127.0.0.1:8011;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_read_timeout 90;
        proxy_redirect off;
    }
}

# 2. RStudio (rstudio.irishof.cloud)
