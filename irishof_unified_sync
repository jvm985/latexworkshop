# Global HTTP to HTTPS redirect
server {
    listen 80;
    server_name r.irishof.cloud latex.irishof.cloud rstudio.irishof.cloud csa.irishof.cloud netwerk.irishof.cloud kalender.irishof.cloud docent.irishof.cloud student.irishof.cloud test.irishof.cloud latexworkshop.irishof.cloud;
    return 301 https://$host$request_uri;
}


